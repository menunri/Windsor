# Windsor API Server Environment Variables

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5175

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Basic Auth for Admin Routes (OBFUSCATION LAYER)
# REQUIRED for production! Generate with: openssl rand -base64 32
ADMIN_BASIC_USER=windsor_admin
ADMIN_BASIC_PASS=generate_a_strong_password_here

# Gmail Configuration (for sending inquiry notifications and replies)
GMAIL_EMAIL=windsoradmin0@gmail.com
