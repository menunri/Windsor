{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-windsor-api.onrender.com/api/:path*"
    }
  ],
  "env": {
    "VITE_API_URL": "https://your-windsor-api.onrender.com/api"
  }
}